# 複製呢個檔案做 .env，填返你自己嘅值。.env 千祈唔好上傳去git。

# 伺服器行喺邊個port
PORT=3000

# ---- AWS Bedrock 設定 ----
# 如果部署去有IAM role嘅Lightsail/EC2，可以留空呢兩個，用返instance role
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# 用邊個Claude型號 (Bedrock model ID)。日常task用sonnet，平/大量task可以轉做haiku
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6

# ---- 共用登入 (簡單版，得幾個同事用先啱) ----
# 部署到有domain嗰陣，呢個共用密碼會用喺basic auth (見部署guide)
# 呢度淨係做local reference，實際login由Caddy處理，唔使填
